{
  "version": 2,
  "build": {
    "env": {
      "CI": "false",
      "NODE_OPTIONS": "--max-old-space-size=1024"
    }
  },
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "backend/**"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/app/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}